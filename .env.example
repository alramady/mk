# ============================================
# Monthly Key - Local Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ─── Database ──────────────────────────────
DATABASE_URL=mysql://root:password@localhost:3306/monthly_rental

# ─── Server ────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Auth (JWT) ────────────────────────────
JWT_SECRET=your-strong-random-secret-key-here-min-32-chars
VITE_APP_ID=monthly-key-local

# ─── OpenAI API (LLM + Image Gen + Voice) ─
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_WHISPER_MODEL=whisper-1

# ─── Local File Storage ───────────────────
UPLOAD_DIR=uploads
PUBLIC_URL=
MAX_UPLOAD_SIZE=52428800

# ─── SMTP Email ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@monthly-key.sa
SMTP_SECURE=false

# ─── Push Notifications (VAPID) ──────────
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── OTP / Verification ─────────────────
OTP_SECRET_PEPPER=change-this-to-a-secure-random-string
OTP_TTL_SECONDS=300

# SMS Provider: "dev" (console log) | "twilio" | "unifonic" (future)
SMS_PROVIDER=dev
SMS_API_KEY=

# Email OTP Provider: "dev" (console log) | "smtp" (uses SMTP config above)
EMAIL_PROVIDER=dev
EMAIL_API_KEY=

# ─── Google Maps (optional) ──────────────
GOOGLE_MAPS_API_KEY=

# ─── Redis (REQUIRED in production) ────────
# In-memory fallback is only acceptable in development/test.
REDIS_URL=redis://localhost:6379

# ─── Payment Webhook Secrets (REQUIRED in production) ──
# Server will NOT start without these in production.
# Obtain from each provider's dashboard.
MOYASAR_WEBHOOK_SECRET=
TABBY_WEBHOOK_SECRET=
TAMARA_WEBHOOK_SECRET=

# ─── WhatsApp (optional but recommended) ───
# Meta App Secret for webhook signature verification
WHATSAPP_APP_SECRET=

# ─── Encryption (strongly recommended) ─────
# 64 hex chars (32 bytes) for AES-256-GCM.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this, integration credentials are stored in PLAINTEXT.
SETTINGS_ENCRYPTION_KEY=

# ─── Legacy (backward compat, optional) ──
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
